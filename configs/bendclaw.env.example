BENDCLAW_LLM_PROVIDER=anthropic

BENDCLAW_ANTHROPIC_API_KEY=
BENDCLAW_ANTHROPIC_BASE_URL=
BENDCLAW_ANTHROPIC_MODEL=claude-opus-4-6

BENDCLAW_OPENAI_API_KEY=
BENDCLAW_OPENAI_BASE_URL=
BENDCLAW_OPENAI_MODEL=gpt-5.4

BENDCLAW_SERVER_HOST=127.0.0.1
BENDCLAW_SERVER_PORT=8082

BENDCLAW_STORE_BACKEND=fs
BENDCLAW_STORE_FS_ROOT_DIR=~/.evotai

