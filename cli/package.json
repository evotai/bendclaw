{
  "name": "@evotai/evot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "evot": "./bin/evot"
  },
  "napi": {
    "binaryName": "evot-napi",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build:napi": "napi build --manifest-path addon/Cargo.toml --output-dir . --release --platform --js src/native/binding.js --dts src/native/binding.d.ts",
    "build:cli": "bun build src/index.ts --compile --define process.env.DEV='\"false\"' --define process.env.NODE_ENV='\"production\"' --outfile dist/evot",
    "dev": "bun run src/index.ts",
    "test": "bun test --path-ignore-patterns 'tests/tui/**'",
    "test:tui": "npx tui-test"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "diff": "^9.0.0",
    "marked": "^15.0.0",
    "string-width": "^8.2.0",
    "strip-ansi": "^7.2.0",
    "wrap-ansi": "^9.0.2"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.1",
    "@types/bun": "^1.2.0",
    "@types/diff": "^8.0.0",
    "typescript": "^5.8.0"
  }
}
