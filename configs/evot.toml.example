[llm]
provider = "anthropic"

# Thinking level controls reasoning depth.
# Valid values: off, minimal, low, medium, high
# - Anthropic: maps to thinking budget_tokens (off=disabled, minimal=128, low=512, medium=2048, high=8192)
# - OpenAI: maps to reasoning_effort (minimal/low→low, medium→medium, high→high, off=omitted)
# thinking_level = "off"

[anthropic]
api_key = ""
base_url = ""
model = "claude-sonnet-4-20250514"

[openai]
api_key = ""
base_url = ""
model = "gpt-4o"

[server]
host = "127.0.0.1"
port = 8082

[store]
backend = "fs"

[store.fs]
root_dir = "~/.evotai"

[store.cloud]
endpoint = ""
api_key = ""
workspace = ""

# [channel.feishu]
# app_id = ""
# app_secret = ""
# mention_only = true
# allow_from = []
